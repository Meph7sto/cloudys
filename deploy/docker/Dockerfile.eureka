# ================================
# Eureka Service Dockerfile
# ================================
FROM eclipse-temurin:17-jre-alpine
LABEL service="eureka-service"
WORKDIR /app
COPY services/eureka-service/target/eureka-service-*-exec.jar app.jar
EXPOSE 8888
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://localhost:8888/actuator/health || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]
