# ================================
# Requirement Analysis Service Dockerfile
# ================================
FROM eclipse-temurin:17-jre-alpine
LABEL service="requirement-analysis-service"
WORKDIR /app
COPY services/requirement-analysis-service/target/requirement-analysis-service-*-exec.jar app.jar
EXPOSE 8004
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://localhost:8004/actuator/health || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]
