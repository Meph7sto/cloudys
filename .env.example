# ================================
# Cloudys 开发环境变量 (Docker Compose)
# ================================
# 复制此文件为 .env 并根据需要修改

# PostgreSQL
POSTGRES_USER=cloudys
POSTGRES_PASSWORD=cloudys_dev
POSTGRES_DB=cloudys
POSTGRES_PORT=5432

# Host port mapping
HOST_GATEWAY_PORT=25698
HOST_FRONTEND_PORT=25699
HOST_POSTGRES_PORT=25700
HOST_EUREKA_PORT=25701
HOST_PYTHON_SIDECAR_PORT=25702
HOST_INFERENCE_PORT=25703
HOST_AUTH_PORT=25704
HOST_PROJECT_PORT=25705
HOST_REQUIREMENT_PORT=25706
HOST_ANALYSIS_PORT=25707
HOST_ADMINER_PORT=25708

# JWT (开发环境密钥，生产环境请使用高强度随机字符串)
JWT_SECRET_KEY=cloudys-jwt-secret-change-in-production
JWT_EXPIRY_HOURS=24

# Python Sidecar / LLM (DeepSeek API)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
SKIP_KB_LOAD=true

# Eureka
EUREKA_HOST=cloudys-eureka
EUREKA_SELF_PRESERVATION=false
EUREKA_SERVER_URL=http://cloudys-eureka:8888/eureka

# Python Bridge (inference-service)
PYTHON_BRIDGE_MANAGE_PROCESS=false
PYTHON_BRIDGE_BASE_URL=http://cloudys-python-sidecar:8000
PYTHON_EXECUTABLE=python
PYTHON_SIDECAR_WORKDIR=python
PYTHON_SIDECAR_APP_MODULE=sidecar_app:app
PYTHON_SIDECAR_HOST=127.0.0.1
PYTHON_SIDECAR_PORT=8000
PYTHON_SIDECAR_STARTUP_TIMEOUT_MS=90000
PYTHON_SIDECAR_WARMUP_ENABLED=true
PYTHON_SIDECAR_WARMUP_PROMPT=ping

# CORS
CORS_ORIGINS=http://localhost:25699,http://127.0.0.1:25699
